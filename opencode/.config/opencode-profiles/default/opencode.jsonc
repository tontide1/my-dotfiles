{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "build",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  // Global Permissions (Áp dụng làm mặc định nếu Agent không ghi đè)
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "ask",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "uv run pytest*": "allow",
      "ruff*": "allow",
      "uv run ruff*": "allow",
      "pyright*": "allow",
      "mypy*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "tree *": "allow"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "task": {
          "*": "deny",
          "review": "allow" // Cho phép gọi subagent review
        },
        "bash": {
          "*": "ask",
          "ls *": "allow",
          "tree *": "allow",
          "find *": "allow",
          "rg *": "allow",
          "grep *": "allow"
        }
      }
    },
    "build": {
      "mode": "primary",
      "reasoningEffort": "high",
      "temperature": 0.0,
      "permission": {
        "edit": "allow",
        "task": {
          "*": "ask",
          "review": "allow", // Tự động gọi review sau khi build xong
          "gemini-cli": "allow" // Cho phép gọi Agent quét codebase
        },
        "bash": {
          "*": "ask",
          "pytest*": "allow",
          "uv run pytest*": "allow",
          "ruff*": "allow",
          "mypy*": "allow",
          "git status*": "allow",
          "git diff*": "allow"
        }
      }
    }
  },
  // Watcher config giữ nguyên (Tối ưu rất tốt cho Python/MLOps)
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".cache/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "htmlcov/**",
      ".coverage*",
      "data/**",
      "datasets/**",
      "artifacts/**",
      "outputs/**",
      "checkpoints/**",
      "mlruns/**",
      "wandb/**",
      ".dvc/cache/**"
    ]
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": [
        "docker.exe",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    }
  }
}