{
  "$schema": "https://opencode.ai/config.json",
  // Tự cập nhật khi khởi động
  "autoupdate": true,
  // Agent mặc định khi mở OpenCode
  "default_agent": "build",
  "small_model": "opencode/minimax-m2.5-free",
  // "provider": {
  //   "9router": {
  //     "npm": "@ai-sdk/openai-compatible",
  //     "options": {
  //       "baseURL": "http://localhost:20128/v1",
  //       "apiKey": "sk_9router"
  //     },
  //     "models": {
  //       "provider/model-id": {
  //         "name": "provider/model-id"
  //       }
  //     }
  //   }
  // },
  // "model": "9router/provider/model-id",
  // Chỉ bật các provider bạn thực sự dùng
  // "enabled_providers": [
  //   "openai",
  //   "opencode",
  //   "github-copilot"
  //   // "9router"
  // ],
  // Tự compact khi session dài
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  // Permissions: mặc định của OpenCode là allow tất cả, nên nên siết lại
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    // Nếu máy bạn không hỗ trợ websearch, đổi thành "ask" hoặc bỏ key này
    "websearch": "allow",
    "edit": "allow",
    "bash": {
      "*": "allow",
      // Git read-only
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      // Test / lint / typecheck
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "uv run pytest*": "allow",
      "ruff*": "allow",
      "uv run ruff*": "allow",
      "pyright*": "allow",
      "mypy*": "allow",
      // Search / inspect
      "rg *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "tree *": "allow",
      // Side-effect lớn
      "git commit *": "ask",
      "git push *": "ask",
      "sudo *": "deny",
      "rm *": "ask",
      "docker system *": "ask",
      "kubectl delete *": "ask",
      "terraform apply *": "ask"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "tree *": "allow"
        }
      }
    },
    "build": {
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "uv run pytest*": "allow",
          "ruff*": "allow",
          "uv run ruff*": "allow",
          "pyright*": "allow",
          "mypy*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "tree *": "allow",
          "git commit *": "ask",
          "git push *": "deny",
          "sudo *": "deny"
        }
      }
    },
    "review": {
      "mode": "subagent",
      "temperature": 0.05,
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "ls *": "allow"
        }
      }
    }
  },
  // Giảm noise cho watcher, đặc biệt hữu ích cho Python + AI workloads
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".cache/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "htmlcov/**",
      ".coverage*",
      "data/**",
      "datasets/**",
      "artifacts/**",
      "outputs/**",
      "checkpoints/**",
      "mlruns/**",
      "wandb/**",
      ".dvc/cache/**"
    ]
  },
  // Giữ nguyên MCP Docker hiện tại của bạn
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": [
        "docker.exe",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    }
  }
}